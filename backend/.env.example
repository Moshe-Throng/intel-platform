# Intel Platform MVP - Environment Variables
# Copy this to .env and fill in your values

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# OpenAI (for GPT-4 auto-tagging)
OPENAI_API_KEY=your-openai-key

# Crawl4AI (your VPS instance)
CRAWL4AI_BASE_URL=http://your-vps-ip:11235

# Postiz (social media publishing)
POSTIZ_API_KEY=your-postiz-key
POSTIZ_BASE_URL=https://app.postiz.com/api/v1
